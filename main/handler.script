local data = require "main.data"
local lock = require "main.lock"

local function domaincheck()
	if not html5 then return true end

	local v = true

	lock.add_domain("armorgames.com")
	lock.add_domain("*.armorgames.com")
	lock.add_domain("*.*.armorgames.com")
	lock.add_domain("*.cache.armorgames.com")
	lock.add_domain("*.cache.armorgames.com")
	lock.add_domain("gamemedia.armorgames.com")
	lock.add_domain("files.armorgames.com")
	lock.add_domain("localhost")
	
	if not lock.verify_domain() then v = false end

	return v
end

function init(self)
	if domaincheck() or not html5 then msg.post(".", "acquire_input_focus") end
	msg.post("@render:", "clear_color", {color = data.hex2rgba("#08050e")})
	math.randomseed(os.time())
	self.restart = nil
	data.loadgamefile()
	data.validate()
	if not html5 then
		defos.set_view_size(nil, nil, data.SCR_W * data.PIXEL, data.SCR_H * data.PIXEL)
	end
end

function on_message(self, message_id, message, sender)
	if message_id == hash("start") then
		msg.post("#menu", "load")
	elseif message_id == hash("show_game") then
		msg.post("#menu", "unload")
		msg.post("#game", "load")
	elseif message_id == hash("show_menu") then
		msg.post("#game", "unload")
		msg.post("#menu", "load")
	elseif message_id == hash("restart_game") then
		msg.post("#game", "unload")
		self.restart = "#game"
	elseif message_id == hash("proxy_unloaded") then
		if self.restart then
			msg.post(self.restart, "load")
			self.restart = nil
		end
	elseif message_id == hash("proxy_loaded") then
		msg.post(sender, "enable")
	end
end	

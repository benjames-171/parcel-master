local data = require "main.data"
local ui = require "main.ui"

function init(self)
	self.node = gui.get_node("container")
	ui.init(self.node)
end

local function nextlevel(self)
	timer.delay(0.5, false, function()
		msg.post("level", "newlevel")
		msg.post("main:/gui", "fadein")
	end)
end

local function tiercomplete(self)
	timer.delay(0.5, false, function()
		msg.post("main:/gui", "fadein")
		msg.post("main:/handler", "show_menu")
	end)
end

local function input(self, action_id, action)
	if action_id == hash("action") and action.pressed then
		if gui.pick_node(gui.get_node("nextlevel"), action.x, action.y) then
			data.level = data.level + 1
			ui.hide(self.node)
			data.state = data.STATE_NULL
			msg.post("main:/gui", "fadeout")
			if data.level <= data.NUM_LEVELS then
				nextlevel(self)
			else
				tiercomplete(self)
			end
			data.sound("menu-select")
		elseif gui.pick_node(gui.get_node("replay"), action.x, action.y) then
			nextlevel(self)
			data.sound("menu-select")
		end
	end
end

local function show(self)
	ui.show(self.node)
	data.sound("win")
	data.state = data.STATE_CLEAR
	for n = 1, 3 do
		local node = gui.get_node("star"..n)
		gui.set_enabled(node, false)
		if n <= data.stars then
			gui.set(node, "scale", vmath.vector3(2))
			timer.delay((n+1)/3, false, function()
				gui.set_enabled(gui.get_node("star"..n), true)
				gui.animate(gui.get_node("star"..n), "scale", 1, gui.EASING_LINEAR, 0.2)
				data.sound("star")
			end)
		end
		data.progress()
		data.savegamefile()
	end
	if data.level >= data.NUM_LEVELS then
		gui.set_text(gui.get_node("text"), "EXIT")
	end
end

function on_message(self, message_id, message, sender)
	if message_id == hash("show") then
		show(self)
	elseif message_id == hash("input") then
		input(self, message.action_id, message.action)
	end
end
